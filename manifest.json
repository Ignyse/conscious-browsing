{
  "manifest_version": 3,
  "name": "Conscious Browsing",
  "version": "1.0",
  "description": "A letter to your future self — interrupts habitual browsing.",
  "permissions": ["declarativeNetRequest", "storage", "tabs"],
  "background": {
    "service_worker": "consciousbrowsing.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["intermediate.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": ["<all_urls>"]
}
